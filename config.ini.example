[DEFAULT]
imagedir = images/
interval = 60
group_size = 20
framebufferdevice = /dev/fb0
colororder = RGB
loglevel = ERROR
logfile = logs/digitalframe.log
showtime = False
showperiodicclock = True
showscheduledclock = False
clockschedule1 = 0 * * * *
clockschedule2 = 30 * * * *
timeformat = %H:%M
timefontsize = 100
timelocation = top-left
timecolor = #ffc800
timebordercolor = #000000
timebordersize = 2
negativetime = False
timealpha = 215
showhourlytime = True
screenoffhour = 1
screenonhour = 6
screenoffhour2 = 0
screenonhour2 = 0
groupsize = 20
selected_folders = 
weak_machine = auto
history_retention_days = 2

[MOTION]
enabled = False
sensitivity = 56
timeout = 500
shutter = 0
gain = 0
auto_sensitivity = True

[SCHEDULE]
enabled = False

[CAMERA]
enabled = False
video_resolution = 1024x768
on_hour = 0
off_hour = 0
on_hour2 = 0
off_hour2 = 0
imagedir_captures = captures/
capture_on_motion = True
capture_mode = image
capture_burst_count = 20
capture_video_duration = 10

[NETWORK]
ap_name = dframe
ap_password = DigitalFrame

[PROXIMITY]
enabled = False
distance_threshold = 4.0
stable_threshold = 0.5
min_samples = 10
ignore_after_hours = 2
timeout = 300
ignored_addresses = 

